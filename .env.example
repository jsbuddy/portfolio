# Resend — contact form email delivery (https://resend.com)
# Required: API key from the Resend dashboard.
RESEND_API_KEY=

# Sender address. Must be on a domain you've verified in Resend.
# Defaults to Resend's shared onboarding sender if unset (fine for testing).
CONTACT_FROM_EMAIL="Jude Francis <hello@judecod.es>"

# Required: the inbox where contact submissions are delivered.
CONTACT_TO_EMAIL=

# PostHog — product analytics (https://posthog.com)
# Project API key ("phc_..."); analytics is disabled when unset.
NEXT_PUBLIC_POSTHOG_KEY=
